def determine_triangle_type(s1, s2, s3):

if s1 == s2 == s3:
return "Equilateral"
elif s1 == s2 or s1 == s3 or s2 == s3:
return "Isosceles"
else:
return "Scalene"

a = int(input("Masukkan sisi 1: "))
b = int(input("Masukkan sisi 2: "))
c = int(input("Masukkan sisi 3: "))

hasil = determine_triangle_type(a, b, c)
print("Jenis segitiga:", hasil)
